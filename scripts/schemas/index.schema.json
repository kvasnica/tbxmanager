{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tbxmanager.com/schema/index.schema.json",
  "title": "Registry Index",
  "description": "Schema for the combined index.json served to tbxmanager clients.",
  "type": "object",
  "required": ["index_version", "generated", "packages"],
  "properties": {
    "index_version": {
      "type": "integer",
      "const": 1
    },
    "generated": {
      "type": "string",
      "description": "ISO 8601 timestamp of index generation"
    },
    "packages": {
      "type": "object",
      "additionalProperties": {
        "$ref": "registry-package.schema.json#/$defs/package_in_index"
      },
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_-]*$"
      }
    }
  },
  "additionalProperties": false,
  "$comment": "The packages object reuses the same structure as registry-package.schema.json but embedded in the index."
}
