{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tbxmanager.com/schema/lockfile.schema.json",
  "title": "tbxmanager Lockfile",
  "description": "Schema for tbxmanager.lock — pins exact resolved versions for reproducible environments.",
  "type": "object",
  "required": ["lockfile_version", "generated", "packages"],
  "properties": {
    "lockfile_version": {
      "type": "integer",
      "const": 1
    },
    "generated": {
      "type": "string",
      "description": "ISO 8601 timestamp of lockfile generation"
    },
    "requires": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "propertyNames": { "pattern": "^[a-z][a-z0-9_-]*$" },
      "description": "Original dependency requirements from tbxmanager.json"
    },
    "packages": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/locked_package"
      },
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_-]*$"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "locked_package": {
      "type": "object",
      "required": ["version", "resolved"],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$"
        },
        "resolved": {
          "type": "object",
          "required": ["url", "sha256", "platform"],
          "properties": {
            "url": { "type": "string", "format": "uri" },
            "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "platform": { "enum": ["win64", "maci64", "maca64", "glnxa64", "all"] }
          },
          "additionalProperties": false
        },
        "dependencies": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$"
          },
          "description": "Pinned dependency versions (exact)"
        }
      },
      "additionalProperties": false
    }
  }
}
